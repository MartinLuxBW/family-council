# Optional: enables real AI cartoon avatar generation (from photo or description).
# Without a key, the app falls back to a built-in cartoon avatar generator.
# Copy this file to .env.local and fill in your key.
OPENAI_API_KEY=

# Optional but recommended: signs session cookies so logins survive restarts.
SESSION_SECRET=

# Shared secret the RunOps tool sends as the x-runops-key header to read /api/public/runops-stats.
# Set this in your Vercel project so the secret is NOT committed to the repo.
RUNOPS_KEY=
